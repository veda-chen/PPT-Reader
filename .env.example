# 智能PPT阅读器 — 环境变量配置
# 复制本文件为 .env 后填入你自己的 Key。

# ── 文本大模型（翻译 / 总结 / 对话 / 全文翻译）必填 ──────────
# 兼容任意 OpenAI 协议的服务商，下面默认指向阿里云 DashScope（千问）。
# DashScope 获取 Key: https://dashscope.console.aliyun.com
QWEN_API_KEY=your_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# 全文翻译并发数（可选，默认 3；服务商 QPS 低时不要调高，否则 429 限流）
# TRANSLATE_CONCURRENCY=3

# ── 图片识图（可选，需本机安装 Node.js）──────────────────────
# 火山引擎 Ark 豆包 VL 模型。vision.js 自带一个默认 Key，可直接用；
# 想换成自己的就取消下面注释并填入。获取 Key: https://console.volcengine.com/ark/
# ARK_API_KEY=your_ark_key_here
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VISION_MODEL=doubao-seed-2-0-lite-260428
